{
  "name": "cards-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "start:prod": "npm run build && node -e \"process.env.NODE_ENV='production'; import('./dist/src/server.js')\"",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:normalize-card-images": "tsx scripts/normalize-card-image-keys.ts",
    "minio:start": "powershell -ExecutionPolicy Bypass -File scripts/start-minio.ps1",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/formbody": "^8.0.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "pg": "^8.16.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^20.19.21",
    "@types/pg": "^8.15.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
